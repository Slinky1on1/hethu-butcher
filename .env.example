# Environment variables — copy to .env and adjust

# Owner PIN for admin login (change before production deploy)
OWNER_PIN=1234

# Session secret — use 32+ random characters in production
SESSION_SECRET=hethu-change-this-to-a-long-random-string-in-production

# Business settings
NEXT_PUBLIC_BUSINESS_NAME=Hethu Mobile Butcher
NEXT_PUBLIC_BUSINESS_PHONE=0746410088
NEXT_PUBLIC_WHATSAPP=27746410088

# Bank details for EFT (shown to customers)
NEXT_PUBLIC_BANK_NAME=Your Bank
NEXT_PUBLIC_BANK_ACCOUNT_NAME=Hethu Mobile Butcher
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=0000000000
NEXT_PUBLIC_BANK_BRANCH=000000

# App URL — set to your live Vercel URL when deployed
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL (Supabase) — required for local dev and production
# DATABASE_URL: use the pooler URL (port 6543, ?pgbouncer=true)
# DIRECT_URL: use the direct connection (port 5432) for migrations
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Supabase Storage for product photos (required on Vercel; optional locally)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=product-images
