# Environment variables — copy to .env and adjust

# Session secret — use 32+ random characters in production
SESSION_SECRET=hethu-change-this-to-a-long-random-string-in-production

# App URL — platform base URL when deployed
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default tenant for legacy /order and /admin redirects (Hethu production client)
DEFAULT_BUSINESS_SLUG=hethu

# Nventrix Central Hub — heartbeat + billing sync (Phase 3)
# CENTRAL_HUB_URL=https://your-nventrix-hub.up.railway.app
# HUB_SECRET=
# CRON_SECRET=

# PostgreSQL (Supabase) — required for local dev and production
# DATABASE_URL: use the pooler URL (port 6543, ?pgbouncer=true)
# DIRECT_URL: use the direct connection (port 5432) for migrations
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Supabase Storage for product photos (required on Vercel; optional locally)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=product-images
