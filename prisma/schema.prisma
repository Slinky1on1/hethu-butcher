generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// A connected business on Nexvintrix Connect (butcher, bakery, mobile retail, etc.)
model Business {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  industry  String   @default("general")
  phone     String   @default("")
  whatsapp  String   @default("")
  bankName  String   @default("")
  bankAccountName String @default("")
  bankAccountNumber String @default("")
  bankBranch String @default("")
  ownerPinHash String
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products          Product[]
  shops             Shop[]
  orders            Order[]
  consignmentDrops  ConsignmentDrop[]
}

model Product {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  packSize   String   @default("")
  price      Int
  imageUrl   String?
  visible    Boolean  @default(true)
  trackStock Boolean  @default(false)
  stock      Int      @default(0)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  consignmentLines ConsignmentLine[]
  saleLines        SaleLine[]
  orderLines       OrderLine[]

  @@index([businessId])
}

model Shop {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  contact    String   @default("")
  phone      String   @default("")
  area       String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  consignmentDrops ConsignmentDrop[]
  sales            Sale[]

  @@index([businessId])
}

model ConsignmentDrop {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  note       String   @default("")
  createdAt  DateTime @default(now())

  lines ConsignmentLine[]

  @@index([businessId])
}

model ConsignmentLine {
  id                String          @id @default(cuid())
  consignmentDropId String
  consignmentDrop   ConsignmentDrop @relation(fields: [consignmentDropId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  quantity          Int
}

model Sale {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  total         Int
  paymentMethod String   @default("cash")
  paid          Boolean  @default(true)
  note          String   @default("")
  createdAt     DateTime @default(now())

  lines SaleLine[]
}

model SaleLine {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Int
}

model Order {
  id                   String    @id @default(cuid())
  businessId           String
  business             Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName         String
  customerPhone        String
  area                 String
  note                 String    @default("")
  paymentMethod        String    @default("cash")
  total                Int
  status               String    @default("pending")
  isConsignment        Boolean   @default(false)
  consignmentStartedAt DateTime?
  paid                 Boolean   @default(false)
  paidAt               DateTime?
  lastReminderAt       DateTime?
  createdAt            DateTime  @default(now())

  lines OrderLine[]

  @@index([businessId])
}

model OrderLine {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Int
}
